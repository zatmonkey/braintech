#!/bin/sh /etc/rc.common
# OpenWrt procd init script for the Braintech agent.
# Install to /etc/init.d/braintech-agent (chmod +x), then:
#   /etc/init.d/braintech-agent enable
#   /etc/init.d/braintech-agent start

USE_PROCD=1
START=95
STOP=10

start_service() {
	# Load device identity / config (BT_DEVICE_ID, BT_PSK, BT_SERVER_URL, ...)
	[ -f /etc/braintech/agent.conf ] && . /etc/braintech/agent.conf

	procd_open_instance
	procd_set_param command /usr/bin/braintech-agent
	procd_set_param env \
		BT_SERVER_URL="${BT_SERVER_URL:-https://getbraintech.com}" \
		BT_DEVICE_ID="${BT_DEVICE_ID}" \
		BT_PSK="${BT_PSK}" \
		BT_ALLOW_EXEC="${BT_ALLOW_EXEC:-0}"
	procd_set_param respawn 3600 5 0   # respawn: throttle window, fail count, retry
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
